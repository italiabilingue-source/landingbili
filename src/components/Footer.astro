<footer class="bg-gray-900 text-white mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {/* Información */}
      <div>
        <h3 class="text-xl font-bold mb-4 text-italia-rojo">Instituto Bilingüe</h3>
        <p class="text-gray-300 text-sm">
          Educación de calidad para los niveles inicial, primaria y secundaria.
        </p>
      </div>

      {/* Enlaces */}
      <div>
        <h4 class="text-lg font-semibold mb-4">Enlaces</h4>
        <ul class="space-y-2 text-gray-300 text-sm">
          <li><a href="/" class="hover:text-italia-rojo transition">Inicio</a></li>
          <li><a href="/institucional" class="hover:text-italia-rojo transition">Institucional</a></li>
          <li><a href="/oferta-educativa" class="hover:text-italia-rojo transition">Oferta Educativa</a></li>
          <li><a href="/noticias" class="hover:text-italia-rojo transition">Noticias</a></li>
        </ul>
      </div>

      {/* Contacto */}
