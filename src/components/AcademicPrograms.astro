---
const levels = [
  {
    id: "jardin",
    tag: "Nivel Inicial",
    title: "Jardín Bilingüe",
    subtitle: "Salas de 3, 4 y 5 años",
    tagline: "Primeros pasos felices",
    description: "En el jardín, el italiano y el español conviven de manera natural a través del juego, el arte y la exploración. Docentes especializadas en primera infancia crean un ambiente donde el afecto es la base de todo aprendizaje.",
    features: ["Doble turno disponible", "Estimulación temprana", "Enseñanza del italiano jugando", "Huerta y taller de arte"],
    icon: "child_care",
    gradient: "from-emerald-600 to-teal-700",
    accent: "#1a6b2f"
  },
  {
    id: "primaria",
    tag: "Nivel Primario",
    title: "Escuela Primaria",
    subtitle: "1.° a 6.° grado · 6 a 12 años",
    tagline: "Descubriendo el mundo",
    description: "Una propuesta académica sólida en español e italiano, con proyectos interdisciplinarios, laboratorio de ciencias, talleres creativos y deportes. Formamos pensadores críticos con una identidad cultural rica.",
    features: ["Certificaciones italianas oficiales", "Laboratorio de ciencias", "Deportes obligatorios", "Olimpiadas y concursos"],
    icon: "menu_book",
    gradient: "from-blue-700 to-indigo-800",
    accent: "#1a3a6e"
  },
  {
    id: "secundaria",
    tag: "Nivel Secundario",
    title: "Escuela Secundaria",
    subtitle: "1.° a 6.° año · 13 a 18 años",
    tagline: "Preparándolos para volar",
    description: "Una secundaria que combina exigencia académica, formación en valores y orientación vocacional. Con italiano avanzado, actividades extracurriculares y acompañamiento personalizado para los egresados.",
    features: ["Certificado PLIDA de italiano", "Orientación vocacional", "Intercambio cultural", "Deporte de competición"],
    icon: "school",
    gradient: "from-rose-700 to-red-800",
    accent: "#c0162a"
  }
];
---

<section id="niveles" class="py-16 bg-surface-container-low overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <div class="section-label justify-center mb-4">Oferta Educativa</div>
      <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl text-on-surface mb-6">
        Tres niveles,<br/>
        <span class="italic font-normal" style="font-family: 'Cormorant Garamond', serif; color: #c0162a;">un solo camino</span>
      </h2>
      <p class="text-on-surface-variant font-body font-light max-w-2xl mx-auto text-[15px] leading-relaxed">
        Acompañamos a cada alumno desde sus primeros pasos en el jardín hasta su egreso en la secundaria, con una propuesta que crece junto a ellos.
      </p>
    </div>

    <!-- Level Cards -->
    <div class="grid lg:grid-cols-3 gap-8">
      {levels.map((level, i) => (
        <div class={`reveal group flex flex-col overflow-hidden rounded-2xl bg-surface-container-lowest shadow-card border border-outline-variant/10 hover:shadow-premium transition-all duration-500 delay-${i * 150}`}>
          
          <!-- Colored top band -->
          <div class={`bg-gradient-to-r ${level.gradient} p-8 text-white relative overflow-hidden`}>
            <div class="absolute -top-6 -right-6 w-28 h-28 bg-white/5 rounded-full"></div>
            <div class="absolute -bottom-10 -right-4 w-40 h-40 bg-white/5 rounded-full"></div>

            <div class="relative z-10">
              <span class="text-[10px] font-bold uppercase tracking-[0.25em] text-white/60 font-body">{level.tag}</span>
              <h3 class="font-headline text-2xl md:text-3xl font-bold mt-1 mb-1">{level.title}</h3>
              <p class="text-white/70 text-sm font-body">{level.subtitle}</p>
            </div>

            <div class="relative z-10 mt-5">
              <span class="material-symbols-outlined text-5xl text-white/20 absolute -top-8 right-0" style="font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;">{level.icon}</span>
            </div>

            <!-- Italian flag strip bottom -->
            <div class="absolute bottom-0 left-0 right-0 h-1 flex">
              <div class="flex-1 bg-secondary/70"></div>
              <div class="flex-1 bg-white/30"></div>
              <div class="flex-1 bg-tertiary/70"></div>
            </div>
          </div>

          <!-- Card Body -->
          <div class="p-8 flex flex-col flex-grow">
            <p class="text-[13px] italic font-medium mb-4" style={`color: ${level.accent};`} style:global="font-family:'Cormorant Garamond',serif;">
              "{level.tagline}"
            </p>
            <p class="text-on-surface-variant text-sm leading-relaxed mb-7 font-body font-light flex-grow">
              {level.description}
            </p>

            <!-- Feature list -->
            <ul class="space-y-2.5 mb-8">
              {level.features.map(feat => (
                <li class="flex items-center gap-3 text-sm font-body text-on-surface">
                  <span 
                    class="material-symbols-outlined text-[16px] shrink-0"
                    style={`color: ${level.accent}; font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 20;`}
                  >check_circle</span>
                  {feat}
                </li>
              ))}
            </ul>

            <a 
              href="/contacto"
              class="group/btn mt-auto inline-flex items-center justify-center gap-2 border-2 py-3 px-6 rounded font-bold text-xs uppercase tracking-widest transition-all duration-300 w-full hover:text-white"
              style={`border-color: ${level.accent}; color: ${level.accent};`}
              onmouseover={`this.style.background='${level.accent}'`}
              onmouseout={`this.style.background='transparent'`}
            >
              Solicitar información
              <span class="material-symbols-outlined text-[15px] group-hover/btn:translate-x-0.5 transition-transform">arrow_forward</span>
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
