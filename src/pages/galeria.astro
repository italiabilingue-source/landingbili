---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';

interface GalleryImage {
  src: string;
  alt: string;
  category: string;
}

const galleryImages: GalleryImage[] = [
  { src: 'https://images.unsplash.com/photo-1427504494785-cdae8dfb7d75?w=400&h=300&fit=crop', alt: 'Aula', category: 'Infraestructura' },
  { src: 'https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?w=400&h=300&fit=crop', alt: 'Estudiantes', category: 'Actividades' },
  { src: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=400&h=300&fit=crop', alt: 'Robótica', category: 'Tecnología' },
  { src: 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=400&h=300&fit=crop', alt: 'Laboratorio', category: 'Infraestructura' },
  { src: 'https://images.unsplash.com/photo-1503454537688-e6c6ff1b912d?w=400&h=300&fit=crop', alt: 'Jardín', category: 'Inicial' },
  { src: 'https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=400&h=300&fit=crop', alt: 'Festival', category: 'Eventos' },
  { src: 'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=400&h=300&fit=crop', alt: 'Ciencias', category: 'Laboratorio' },
  { src: 'https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=400&h=300&fit=crop', alt: 'Deportes', category: 'Actividades' },
  { src: 'https://images.unsplash.com/photo-1507842217343-583684e55b3e?w=400&h=300&fit=crop', alt: 'Biblioteca', category: 'Infraestructura' },
  { src: 'https://images.unsplash.com/photo-1578496781514-db2d14f52d53?w=400&h=300&fit=crop', alt: 'Clase', category: 'Actividades' },
  { src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=400&h=300&fit=crop', alt: 'Charla', category: 'Eventos' },
  { src: 'https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=400&h=300&fit=crop', alt: 'Comedor', category: 'Servicios' },
];
---

<Layout title="Galería" description="Galería de fotos de nuestro instituto">
  <Navbar currentPage="/galeria" />

  <div class="pt-20"></div>

  <Hero
    title="Galería de Fotos"
    subtitle="Conoce nuestras instalaciones y actividades"
  />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    {/* Filtros */}
    <div class="flex justify-center gap-3 mb-8 flex-wrap">
      <button class="filter-btn bg-italia-rojo text-white px-4 py-2 rounded-lg font-semibold" data-filter="all">
        Todos
      </button>
      <button class="filter-btn bg-gray-200 text-gray-800 px-4 py-2 rounded-lg font-semibold hover:bg-italia-rojo hover:text-white transition" data-filter="Infraestructura">
        Infraestructura
      </button>
      <button class="filter-btn bg-gray-200 text-gray-800 px-4 py-2 rounded-lg font-semibold hover:bg-italia-verde hover:text-white transition" data-filter="Actividades">
        Actividades
      </button>
      <button class="filter-btn bg-gray-200 text-gray-800 px-4 py-2 rounded-lg font-semibold hover:bg-italia-celeste hover:text-white transition" data-filter="Eventos">
        Eventos
      </button>
      <button class="filter-btn bg-gray-200 text-gray-800 px-4 py-2 rounded-lg font-semibold hover:bg-italia-verde hover:text-white transition" data-filter="Tecnología">
        Tecnología
      </button>
    </div>

    {/* Galería */}
    <div class="gallery grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {galleryImages.map((image) => (
        <div
          class="gallery-item overflow-hidden rounded-lg shadow-lg cursor-pointer fade-in-scroll"
          data-category={image.category}
        >
          <div class="relative overflow-hidden h-64 bg-gray-300">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover hover:scale-110 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-black/30 opacity-0 hover:opacity-100 transition-opacity flex items-center justify-center">
              <span class="text-white text-sm font-semibold">{image.alt}</span>
            </div>
          </div>
          <div class="p-4 bg-white">
            <span class="text-xs text-italia-rojo font-semibold">{image.category}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="bg-gradient-to-r from-italia-verde to-italia-celeste text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-bold mb-4">¿Quieres conocer nuestro instituto en persona?</h2>
      <a href="/contacto" class="inline-block px-8 py-3 bg-white text-italia-verde font-bold rounded-lg hover:bg-gray-100 transition">
        Agendar visita
      </a>
    </div>
  </section>

  <Footer />

  <script>
    // Filtrado de galería
    const filterBtns = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        // Actualizar botones activos
        filterBtns.forEach(b => b.classList.remove('!bg-italia-rojo', '!bg-italia-verde', '!bg-italia-celeste', '!text-white'));
        btn.classList.add('!bg-italia-rojo', '!text-white');

        // Filtrar imágenes
        galleryItems.forEach(item => {
          const category = item.getAttribute('data-category');
          if (filter === 'all' || category === filter) {
            item.style.display = 'block';
            setTimeout(() => item.style.opacity = '1', 10);
          } else {
            item.style.opacity = '0';
            setTimeout(() => item.style.display = 'none', 300);
          }
        });
      });
    });

    // Scroll animation
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.fade-in-scroll').forEach(el => {
      observer.observe(el);
    });
  </script>
</Layout>
