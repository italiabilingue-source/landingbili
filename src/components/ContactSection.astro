---
---
<section id="contacto" class="relative bg-surface overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 py-24">
    
    <div class="text-center mb-16">
      <span class="text-secondary font-bold tracking-widest uppercase text-xs">Información</span>
      <h2 class="font-headline text-4xl md:text-5xl mt-2 mb-4 text-primary">Contacto</h2>
      <p class="text-on-surface-variant max-w-2xl mx-auto font-light">
        Comunicate con nosotros de manera simple y rápida. Estamos para resolver tus dudas.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16">
      
      <!-- Contact Info & Map -->
      <div class="flex flex-col gap-10">
        <div class="space-y-8 bg-surface-container-low p-8 rounded shadow-premium border border-outline-variant/10">
          <div class="flex gap-4 items-start">
            <span class="material-symbols-outlined text-secondary pt-0.5">location_on</span>
            <div>
              <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface-variant mb-1">Dirección</h4>
              <p class="text-base text-on-surface">Av. del Libertador 1234, <br /> Concepción del Uruguay, Entre Ríos.</p>
            </div>
          </div>

          <div class="flex gap-4 items-start">
            <span class="material-symbols-outlined text-secondary pt-0.5">mail</span>
            <div>
              <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface-variant mb-1">Email</h4>
              <p class="text-base text-on-surface">informes@itbili.edu.ar</p>
            </div>
          </div>

          <div class="flex gap-4 items-start">
            <span class="material-symbols-outlined text-secondary pt-0.5">phone_iphone</span>
            <div>
              <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface-variant mb-1">WhatsApp de Admisiones</h4>
              <p class="text-base font-bold text-primary">+54 9 3442 123456</p>
            </div>
          </div>
        </div>

        <!-- Map Placeholder -->
        <div class="h-64 lg:h-full min-h-[16rem] bg-surface-container-high rounded-sm shadow-premium overflow-hidden relative group">
          <div class="absolute inset-0 bg-[url('https://maps.googleapis.com/maps/api/staticmap?center=-32.4842,-58.2329&zoom=15&size=600x400&scale=2&key=')] bg-cover bg-center grayscale opacity-80 group-hover:grayscale-0 transition-all duration-500"></div>
          <div class="absolute inset-0 flex items-center justify-center bg-black/10 pointer-events-none group-hover:bg-transparent transition-colors">
            <a href="https://maps.google.com" target="_blank" class="bg-white/90 backdrop-blur-md px-6 py-3 rounded text-xs font-bold uppercase tracking-widest text-primary shadow-lg pointer-events-auto hover:bg-primary hover:text-white transition-colors">Ver en Google Maps</a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-surface-container-lowest p-8 md:p-10 rounded shadow-premium border-t-4 border-primary">
        <h3 class="font-headline text-2xl mb-8 font-bold text-on-surface">Envianos tu consulta</h3>
        <form class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div class="flex flex-col">
              <label for="nombre" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Nombre completo</label>
              <input type="text" id="nombre" class="bg-surface-container border border-outline-variant/30 rounded px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-sm" placeholder="Ej. Juan Pérez" required>
            </div>
            <div class="flex flex-col">
              <label for="telefono" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Teléfono</label>
              <input type="tel" id="telefono" class="bg-surface-container border border-outline-variant/30 rounded px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-sm" placeholder="Ej. 3442 123456" required>
            </div>
          </div>
          
          <div class="flex flex-col">
            <label for="email" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Email</label>
            <input type="email" id="email" class="bg-surface-container border border-outline-variant/30 rounded px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-sm" placeholder="tu@email.com" required>
          </div>

          <div class="flex flex-col">
            <label for="mensaje" class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Mensaje</label>
            <textarea id="mensaje" rows="4" class="bg-surface-container border border-outline-variant/30 rounded px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-sm resize-none" placeholder="¿En qué te podemos ayudar?" required></textarea>
          </div>

          <button type="submit" class="w-full bg-primary text-white py-4 rounded font-bold uppercase tracking-widest hover:bg-primary-container transition-colors shadow-lg mt-4 flex items-center justify-center gap-2">
            Enviar Mensaje
            <span class="material-symbols-outlined text-[18px]">send</span>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
