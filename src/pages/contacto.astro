---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto" description="Ponte en contacto con Instituto Bilingüe República de Italia">
  <Navbar currentPage="/contacto" />

  <div class="pt-20"></div>

  <Hero
    title="Contacto"
    subtitle="¡Queremos escucharte!"
  />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid md:grid-cols-2 gap-12">
      {/* Formulario */}
      <div>
        <h2 class="section-title">Envíanos un mensaje</h2>

        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Nombre completo</label>
            <input
              type="text"
              name="nombre"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-italia-rojo focus:border-transparent outline-none transition"
              placeholder="Tu nombre"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input
              type="email"
              name="email"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-italia-rojo focus:border-transparent outline-none transition"
              placeholder="tu@email.com"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Teléfono</label>
            <input
              type="tel"
              name="telefono"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-italia-rojo focus:border-transparent outline-none transition"
              placeholder="Tu teléfono"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Asunto</label>
            <select
              name="asunto"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-italia-rojo focus:border-transparent outline-none transition"
            >
              <option>Selecciona un asunto</option>
              <option>Información sobre Nivel Inicial</option>
              <option>Información sobre Nivel Primario</option>
              <option>Información sobre Nivel Secundario</option>
              <option>Inscripción</option>
              <option>Otro</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Mensaje</label>
            <textarea
              name="mensaje"
              rows="5"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-italia-rojo focus:border-transparent outline-none transition resize-none"
              placeholder="Cuéntanos cómo podemos ayudarte..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-primary w-full"
          >
            Enviar mensaje
          </button>
        </form>

        <p class="text-xs text-gray-500 mt-4">
          Nota: Reemplaza YOUR_FORM_ID en el atributo action del formulario con tu ID de Formspree
        </p>
      </div>

      {/* Información de contacto */}
      <div>
        <h2 class="section-title">Información de Contacto</h2>

        <div class="space-y-8 mb-8">
          <div class="flex items-start">
            <div class="w-12 h-12 bg-italia-rojo/10 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
              <span class="text-2xl">📧</span>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1">Email</h3>
              <a href="mailto:info@institutobilingue.edu.ar" class="text-italia-rojo hover:text-italia-verde transition">
                info@institutobilingue.edu.ar
              </a>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 bg-italia-verde/10 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
              <span class="text-2xl">📞</span>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1">Teléfono</h3>
              <a href="tel:+5551234567" class="text-Italia-verde hover:text-italia-rojo transition">
                (555) 123-4567
              </a>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 bg-italia-celeste/10 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
              <span class="text-2xl">📍</span>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1">Dirección</h3>
              <p class="text-gray-600">
                Calle Principal 1234<br/>
                Buenos Aires, Argentina
              </p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 bg-italia-rojo/10 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
              <span class="text-2xl">⏰</span>
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1">Horario de atención</h3>
              <p class="text-gray-600">
                Lunes a Viernes: 8:00 - 18:00<br/>
                Sábado: 9:00 - 13:00
              </p>
            </div>
          </div>
        </div>

        {/* Botones de contacto */}
        <div class="space-y-3">
          <a
            href="https://wa.me/5551234567"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 w-full px-6 py-3 bg-[#25D366] hover:bg-[#20c353] text-white font-bold rounded-lg transition"
          >
            <span>💬</span> Contactar por WhatsApp
          </a>

          <div class="text-center text-sm text-gray-600 mt-4">
            <p class="font-semibold mb-2">Síguenos en redes sociales:</p>
            <div class="flex justify-center gap-4">
              <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="text-[#1877F2] hover:underline">
                Facebook
              </a>
              <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-[#E4405F] hover:underline">
                Instagram
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Mapa */}
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="section-title text-center">Ubicación</h2>

      <div class="rounded-lg overflow-hidden shadow-lg h-96">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3283.8921093261846!2d-58.38160522345095!3d-34.60368517107839!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95a334ec4e5e0001%3A0x1234567890ab!2sBuenos%20Aires%2C%20Argentina!5e0!3m2!1ses!2sar!4v1234567890"
          width="100%"
          height="100%"
          style="border:0;"
          allowFullScreen=""
          loading="lazy"
          referrerPolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    // Validación simple del formulario
    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('submit', (e) => {
        const email = form.querySelector('input[name="email"]').value;
        const nombre = form.querySelector('input[name="nombre"]').value;

        if (!email || !nombre) {
          e.preventDefault();
          alert('Por favor completa todos los campos requeridos');
        }
      });
    }
  </script>
</Layout>
