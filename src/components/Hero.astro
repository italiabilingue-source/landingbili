---
import { Image } from 'astro:assets';
import schoolFront from '../assets/school-front.jpg';
---

<section class="relative min-h-[100svh] flex items-end overflow-hidden bg-slate-950">
  
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <Image 
      src={schoolFront} 
      alt="Frente del Instituto República de Italia en Concepción del Uruguay" 
      class="w-full h-full object-cover scale-[1.04]"
      loading="eager"
    />
    <!-- Multi-layer cinematic overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/70 to-slate-800/30"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-slate-950/60 via-transparent to-transparent"></div>
  </div>

  <!-- Animated floating shapes (decorative, blurred) -->
  <div class="absolute top-1/4 right-[8%] w-80 h-80 bg-secondary/10 rounded-full blur-[80px] animate-pulse z-0 pointer-events-none"></div>
  <div class="absolute bottom-1/3 right-1/4 w-60 h-60 bg-primary/20 rounded-full blur-[60px] z-0 pointer-events-none" style="animation: float 6s ease-in-out infinite;"></div>

  <!-- Italian flag vertical strip (left edge) -->
  <div class="absolute left-0 top-0 bottom-0 w-1.5 flex flex-col z-10">
    <div class="flex-1 bg-secondary"></div>
    <div class="flex-1 bg-white/40"></div>
    <div class="flex-1 bg-tertiary"></div>
  </div>

  <!-- Main Content -->
  <div class="relative z-20 w-full max-w-7xl mx-auto px-8 md:px-12 pb-20 md:pb-28 pt-36">
    
    <!-- Eyebrow badge -->
    <div id="hero-badge" class="inline-flex items-center gap-2.5 mb-10 px-5 py-2.5 rounded-full border border-white/15 bg-white/5 backdrop-blur-md text-white">
      <div class="flex gap-0.5">
        <div class="h-3 w-1.5 bg-secondary rounded-full"></div>
        <div class="h-3 w-1.5 bg-white/70 rounded-full"></div>
        <div class="h-3 w-1.5 bg-tertiary rounded-full"></div>
      </div>
      <span class="text-[11px] font-bold uppercase tracking-[0.3em] font-body">Concepción del Uruguay · Desde 1960</span>
    </div>

    <!-- Big Headline -->
    <h1 id="hero-title" class="font-headline font-bold text-white leading-[0.95] mb-8">
      <span class="block text-[3.2rem] sm:text-[4.5rem] md:text-[5.8rem] lg:text-[7rem] tracking-tight" style="text-shadow: 0 8px 48px rgba(0,0,0,0.7)">
        Una escuela
      </span>
      <span class="block text-[2.2rem] sm:text-[3.2rem] md:text-[4rem] lg:text-[5rem] font-light italic text-white/85 mt-2" style="font-family: 'Cormorant Garamond', serif;">
        con alma italiana.
      </span>
    </h1>

    <!-- Subtitle -->
    <p id="hero-sub" class="text-white/75 font-body font-light text-lg md:text-xl max-w-2xl leading-relaxed mb-12">
      Jardín, Primaria y Secundaria con enseñanza bilingüe ítalo-española, formación en valores, deportes y cultura para toda la vida.
    </p>

    <!-- CTA Row -->
    <div id="hero-ctas" class="flex flex-col sm:flex-row gap-4 sm:gap-5">
      <a 
        href="#contacto" 
        class="group inline-flex items-center justify-center gap-2.5 bg-white text-primary px-8 py-4.5 rounded font-bold text-sm uppercase tracking-widest hover:bg-surface transition-all duration-300 shadow-2xl hover:shadow-primary/20"
      >
        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">school</span>
        Inscripciones 2026
      </a>
      <a 
        href="#vida-escolar"
        class="inline-flex items-center justify-center gap-2.5 border-2 border-white/25 text-white px-8 py-4.5 rounded font-bold text-sm uppercase tracking-widest hover:bg-white/10 hover:border-white/50 transition-all duration-300 backdrop-blur-sm"
      >
        <span class="material-symbols-outlined text-[18px]">explore</span>
        Conocer el colegio
      </a>
    </div>

    <!-- Quick stats row -->
    <div id="hero-stats" class="mt-20 flex flex-wrap gap-x-10 gap-y-5 border-t border-white/10 pt-8">
      {[
        { n: '60', suffix: '+', label: 'Años de historia' },
        { n: '3', suffix: '', label: 'Niveles educativos' },
        { n: '100', suffix: '%', label: 'Bilingüe italiano' },
        { n: '15', suffix: '+', label: 'Disciplinas deportivas' },
      ].map(stat => (
        <div class="flex flex-col">
          <span class="font-headline text-3xl md:text-4xl font-bold text-white leading-none">
            <span class="counter" data-target={stat.n} data-suffix={stat.suffix}>{stat.n}{stat.suffix}</span>
          </span>
          <span class="text-[11px] uppercase tracking-widest text-white/50 font-medium mt-1 font-body">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 opacity-60">
    <span class="text-[10px] text-white uppercase tracking-widest font-body">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-white to-transparent animate-pulse"></div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-18px) scale(1.05); }
  }

  #hero-badge {
    animation: fadeInDown 0.9s cubic-bezier(0.16,1,0.3,1) 0.2s both;
  }
  #hero-title {
    animation: fadeInUp 1s cubic-bezier(0.16,1,0.3,1) 0.4s both;
  }
  #hero-sub {
    animation: fadeInUp 1s cubic-bezier(0.16,1,0.3,1) 0.6s both;
  }
  #hero-ctas {
    animation: fadeInUp 1s cubic-bezier(0.16,1,0.3,1) 0.75s both;
  }
  #hero-stats {
    animation: fadeInUp 1s cubic-bezier(0.16,1,0.3,1) 0.9s both;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Trigger counter animations when in view */
  .counter { display: inline-block; }
</style>

<script>
  // Counter animation specific to hero stats
  const heroCounters = document.querySelectorAll('#hero-stats .counter');
  let heroAnimated = false;

  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !heroAnimated) {
        heroAnimated = true;
        heroCounters.forEach(el => {
          const target = parseInt(el.getAttribute('data-target') || '0');
          const suffix = el.getAttribute('data-suffix') || '';
          let current = 0;
          const step = target / 60;
          const timer = setInterval(() => {
            current += step;
            if (current >= target) { current = target; clearInterval(timer); }
            el.textContent = Math.floor(current) + suffix;
          }, 25);
        });
      }
    });
  }, { threshold: 0.3 });

  const statsSection = document.getElementById('hero-stats');
  if (statsSection) heroObserver.observe(statsSection);
</script>
