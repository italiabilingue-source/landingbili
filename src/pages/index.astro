---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import SchoolLife from '../components/SchoolLife.astro';
import AcademicPrograms from '../components/AcademicPrograms.astro';
import ItalianBanner from '../components/ItalianBanner.astro';
import About from '../components/About.astro';
import Admissions from '../components/Admissions.astro';
import News from '../components/News.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';

const title = "Instituto República de Italia | Bilingüe Italiano · Concepción del Uruguay";
const description = "Institución bilingüe ítalo-española con Jardín, Primaria y Secundaria en Concepción del Uruguay. Deportes, certificaciones PLIDA/CILS, arte y más de 60 años de trayectoria.";
---

<Layout title={title} description={description}>
  <Navbar />
  
  <main class="overflow-x-hidden">
    <!-- 1. Hero: imagen del colegio con headline y stats -->
    <Hero />

    <!-- 2. Por qué elegirnos: 6 pilares -->
    <WhyChooseUs />

    <!-- 3. Vida escolar: grid fotográfico cinematic -->
    <SchoolLife />

    <!-- 4. Niveles educativos: Jardín / Primaria / Secundaria -->
    <AcademicPrograms />

    <!-- 5. El italiano + Deportes (nueva sección) -->
    <ItalianBanner />

    <!-- 6. Sobre nosotros: historia e identidad -->
    <About />

    <!-- 7. Admisiones: proceso en pasos -->
    <Admissions />

    <!-- 8. Noticias y Eventos -->
    <News />

    <!-- 9. Contacto -->
    <ContactSection />
  </main>

  <Footer />
</Layout>

<style>
  main {
    overflow-x: hidden;
  }
</style>
