---
const levels = [
  {
    title: "Jardín Bilingüe",
    age: "Salas de 3, 4 y 5 años",
    focus: "Primeros pasos felices",
    differential: "Aprenden inglés jugando, en aulas donde el cariño y la contención son lo más importante."
  },
  {
    title: "Escuela Primaria",
    age: "6 a 12 años",
    focus: "Descubriendo el mundo",
    differential: "Desarrollan sus talentos con una enseñanza muy cercana y bilingüismo natural y certificado."
  },
  {
    title: "Escuela Secundaria",
    age: "13 a 18 años",
    focus: "Preparándolos para volar",
    differential: "Crecimiento seguro, con valores fuertes y las raíces necesarias para abrazar su futuro."
  }
];
---

<section id="academico" class="py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-secondary font-bold tracking-widest uppercase text-xs">Acompañamiento</span>
      <h2 class="font-headline text-4xl mb-4 text-primary">Oferta Educativa</h2>
      <p class="text-on-surface-variant max-w-2xl mx-auto font-light">
        Acompañamos cada etapa de su crecimiento con un enfoque donde sentirse bien es la base para aprender mejor.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {levels.map((level) => (
        <a 
          href="#contacto" 
          class="group bg-surface-container-lowest p-8 rounded shadow-premium border-l-4 border-transparent hover:border-primary transition-all flex flex-col h-full"
        >
          <h3 class="font-headline text-2xl mb-6 text-primary group-hover:scale-105 transition-transform origin-left">
            {level.title}
          </h3>
          
          <div class="space-y-4 flex-grow">
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-secondary text-sm pt-1">calendar_today</span>
              <div>
                <span class="block text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Edad</span>
                <p class="text-sm font-medium">{level.age}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-secondary text-sm pt-1">psychology</span>
              <div>
                <span class="block text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Enfoque</span>
                <p class="text-sm">{level.focus}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-secondary text-sm pt-1">star</span>
              <div>
                <span class="block text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Diferencial</span>
                <p class="text-sm italic text-on-surface-variant line-clamp-2">
                  {level.differential}
                </p>
              </div>
            </div>
          </div>

          <div class="mt-8 flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
            Más información
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
