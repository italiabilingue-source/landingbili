---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import LevelsPreview from '../components/LevelsPreview.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ItalianBanner from '../components/ItalianBanner.astro';
import News from '../components/News.astro';
import Footer from '../components/Footer.astro';

const title = "Instituto República de Italia | Bilingüe Italiano · Concepción del Uruguay";
const description = "Institución bilingüe ítalo-española con Jardín, Primaria y Secundaria en Concepción del Uruguay. Deportes, certificaciones PLIDA/CILS, arte y más de 60 años de trayectoria.";
---

<Layout title={title} description={description}>
  <Navbar />
  
  <main class="overflow-x-hidden">
    <!-- 1. Hero: imagen del colegio con headline y stats -->
    <Hero />

    <!-- 1b. Resumen de niveles -->
    <LevelsPreview />

    <!-- 2. Por qué elegirnos: Breve resumen de la propuesta -->
    <WhyChooseUs />

    <!-- 3. El italiano + Deportes: Nuestro diferencial -->
    <ItalianBanner />

    <!-- 4. Noticias y Eventos: Lo que sucede hoy -->
    <News />
  </main>

  <Footer />
</Layout>

<style>
  main {
    overflow-x: hidden;
  }
</style>
