<footer class="bg-primary text-white py-16 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <h3 class="font-headline text-2xl font-bold mb-4">República de Italia</h3>
        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          Excelencia académica y formación bilingüe en el corazón de Concepción del Uruguay. Más de 60 años educando con valores.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-col gap-3">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-4 text-white/50">Navegación</h4>
        <a href="#admisiones" class="hover:text-secondary transition-colors text-sm">Proceso de Admisión</a>
        <a href="#academico" class="hover:text-secondary transition-colors text-sm">Propuesta Educativa</a>
        <a href="#institucional" class="hover:text-secondary transition-colors text-sm">Nuestra Historia</a>
        <a href="#contacto" class="hover:text-secondary transition-colors text-sm">Trabajá con nosotros</a>
      </div>

      <!-- Legal -->
      <div class="flex flex-col gap-3">
        <h4 class="font-bold text-xs uppercase tracking-[0.2em] mb-4 text-white/50">Legal</h4>
        <a href="#" class="hover:text-secondary transition-colors text-sm opacity-50">Política de Privacidad</a>
        <a href="#" class="hover:text-secondary transition-colors text-sm opacity-50">Términos Académicos</a>
      </div>
    </div>

    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase tracking-widest text-white/30 font-bold">
      <p>© 2024 Instituto Bilingüe República de Italia. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <span>C. del Uruguay, Entre Ríos</span>
        <span>Artesanalmente diseñado</span>
      </div>
    </div>
  </div>
</footer>
