---
export interface Props {
  date: string;
  title: string;
  excerpt: string;
  image: string;
  link?: string;
}

const { date, title, excerpt, image, link } = Astro.props;
---

<article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow fade-in">
  <div class="h-48 overflow-hidden bg-gray-300">
    <img src={image} alt={title} class="w-full h-full object-cover hover:scale-105 transition-transform" />
  </div>
  <div class="p-6">
    <span class="text-italia-rojo text-sm font-semibold">{date}</span>
    <h3 class="text-lg font-bold text-gray-800 mt-2 mb-2">{title}</h3>
    <p class="text-gray-600 text-sm mb-4">{excerpt}</p>
    {link && (
      <a href={link} class="text-italia-rojo font-semibold hover:text-italia-verde transition">
        Leer más →
      </a>
    )}
  </div>
</article>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
</style>
