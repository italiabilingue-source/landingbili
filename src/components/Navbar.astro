---
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.jpg';
---

<nav id="main-nav" class="fixed top-0 z-[90] glass-nav w-full py-4 px-6 md:px-12 transition-all duration-500 transform -translate-y-full opacity-0 shadow-sm">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <!-- Logo & Title -->
    <a href="/" class="flex items-center gap-3">
      <Image 
        src={logoImage} 
        alt="Logo Instituto República de Italia" 
        width={48} 
        height={48} 
        class="h-10 w-auto"
      />
      <div class="flex flex-col">
        <span class="font-headline font-bold text-primary leading-none text-base md:text-lg tracking-tight">República de Italia</span>
        <span class="hidden sm:block text-[10px] uppercase tracking-[0.2em] text-on-surface-variant font-medium">Instituto Bilingüe</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8">
      <div class="flex gap-6">
        <a href="#institucional" class="text-sm font-medium hover:text-primary transition-colors">Institucional</a>
        <a href="#academico" class="text-sm font-medium hover:text-primary transition-colors">Académico</a>
        <a href="#admisiones" class="text-sm font-medium hover:text-primary transition-colors">Admisiones</a>
        <a href="#noticias" class="text-sm font-medium hover:text-primary transition-colors">Noticias</a>
        <a href="#contacto" class="text-sm font-medium hover:text-primary transition-colors">Contacto</a>
      </div>
      
      <a 
        href="#contacto" 
        class="bg-primary text-white px-6 py-2.5 rounded text-xs font-bold uppercase tracking-wider hover:brightness-110 hover:shadow-lg transition-all"
      >
        Solicitar información
      </a>
    </div>

    <!-- Mobile CTA & Menu -->
    <div class="flex items-center gap-3 md:hidden">
      <a 
        href="#contacto" 
        class="bg-primary text-white px-4 py-2 rounded text-[10px] font-bold uppercase tracking-wider"
      >
        Pedir Info
      </a>
      <button class="text-primary p-1">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('main-nav');
    if (!nav) return;
    
    window.addEventListener('scroll', () => {
      // Mostrar la navbar cuando scrolea un poco (ej: 150px)
      if (window.scrollY > 150) {
        nav.classList.remove('-translate-y-full', 'opacity-0');
        nav.classList.add('translate-y-0', 'opacity-100');
      } else {
        nav.classList.add('-translate-y-full', 'opacity-0');
        nav.classList.remove('translate-y-0', 'opacity-100');
      }
    });
  });
</script>
