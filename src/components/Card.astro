---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  link?: string;
  linkText?: string;
}

const { title, description, image, link, linkText } = Astro.props;
---

<div class="bg-white rounded-lg shadow-lg hover:shadow-xl transition-shadow overflow-hidden fade-in">
  {image && (
    <div class="h-48 overflow-hidden bg-gray-200">
      <img src={image} alt={title} class="w-full h-full object-cover hover:scale-105 transition-transform" />
    </div>
  )}
  <div class="p-6">
    <h3 class="text-xl font-bold text-gray-800 mb-2">{title}</h3>
    {description && (
      <p class="text-gray-600 text-sm mb-4">{description}</p>
    )}
    {link && (
      <a href={link} class="inline-block text-italia-rojo font-semibold hover:text-italia-verde transition">
        {linkText || 'Más información'} →
      </a>
    )}
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
</style>
