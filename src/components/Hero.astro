---
import { Image } from 'astro:assets';
import schoolFront from '../assets/school-front.jpg';
---

<section class="relative h-[90vh] min-h-[700px] flex items-center justify-center overflow-hidden bg-primary-container">
  <!-- Background Image with Sophisticated Overlay -->
  <div class="absolute inset-0 z-0">
    <Image 
      src={schoolFront} 
      alt="Frente del Instituto República de Italia en Concepción del Uruguay" 
      class="w-full h-full object-cover scale-105"
    />
    <!-- Multi-layer gradient for Archival feel -->
    <div class="absolute inset-0 bg-on-surface/50 z-10 backdrop-blur-[2px]"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-on-surface/90 via-primary/20 to-transparent z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-surface z-10"></div>
  </div>

  <!-- Content Container -->
  <div class="relative z-20 text-center px-6 max-w-6xl mt-8">
    <!-- Refined Tricolor Accent -->
    <div class="inline-flex items-center gap-1 mb-10 px-4 py-2 bg-on-surface/20 backdrop-blur-md rounded-sm border border-white/5">
      <div class="h-4 w-1 bg-secondary rounded-full"></div>
      <div class="h-4 w-1 bg-white rounded-full"></div>
      <div class="h-4 w-1 bg-tertiary rounded-full"></div>
      <span class="text-[10px] uppercase tracking-[0.3em] font-bold text-white/80 ml-2">Desde 1964</span>
    </div>

    <!-- Typography: Editorial Authority -->
    <div class="space-y-4">
      <h1 class="font-headline text-4xl sm:text-5xl md:text-8xl text-white tracking-tight leading-[0.9] font-bold drop-shadow-2xl">
        Educación bilingüe <br class="hidden md:block" />
        <span class="text-white/40 block md:inline font-light">en </span>
        <span class="text-white font-normal italic decoration-white/30 underline-offset-8">Concepción del Uruguay</span>
      </h1>
      
      <p class="text-white/80 text-base md:text-xl font-body font-light max-w-2xl mx-auto tracking-wide leading-relaxed pt-6">
        Un camino educativo desde el jardín hasta la secundaria, <br class="hidden md:block" />
        formando líderes con excelencia académica y <span class="text-white font-medium italic underline decoration-secondary decoration-2 underline-offset-4">valores humanos</span>.
      </p>
    </div>

    <!-- CTAs with Premium Styling -->
    <div class="flex flex-col md:flex-row gap-6 justify-center items-center mt-12 bg-on-surface/10 p-4 md:p-2 rounded-lg backdrop-blur-sm border border-white/10 max-w-fit mx-auto">
      <a 
        href="#contacto" 
        class="bg-white text-primary px-10 py-4 rounded font-bold text-xs uppercase tracking-widest hover:bg-surface transition-all shadow-2xl w-full md:w-auto text-center"
      >
        Solicitar información
      </a>
      <a 
        href="https://wa.me/5493442123456" 
        target="_blank"
        class="text-white hover:text-secondary px-8 py-4 rounded font-bold text-xs uppercase tracking-widest transition-all w-full md:w-auto text-center flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined text-lg">chat</span>
        Contactar por WhatsApp
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <span class="material-symbols-outlined text-white/30 text-3xl">expand_more</span>
  </div>
</section>

<style>
  /* Custom drop shadow for the massive headline */
  h1 {
    text-shadow: 0 10px 40px rgba(0,0,0,0.5);
  }
</style>
