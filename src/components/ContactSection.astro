---
---
<section id="contacto" class="relative bg-surface overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 py-24 flex flex-col md:flex-row gap-16">
    <!-- Info -->
    <div class="md:w-1/2">
      <h2 class="font-headline text-4xl mb-8 text-primary">Contacto</h2>
      
      <div class="space-y-8">
        <div class="flex gap-4">
          <span class="material-symbols-outlined text-secondary">location_on</span>
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface-variant mb-1">Dirección</h4>
            <p class="text-lg">Av. del Libertador 1234, <br /> Concepción del Uruguay, Entre Ríos.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="material-symbols-outlined text-secondary">mail</span>
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface-variant mb-1">Email</h4>
            <p class="text-lg">informes@itbili.edu.ar</p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="material-symbols-outlined text-secondary">phone_iphone</span>
          <div>
            <h4 class="font-bold text-sm uppercase tracking-widest text-on-surface-variant mb-1">WhatsApp de Admisiones</h4>
            <p class="text-lg font-bold text-primary">+54 9 3442 123456</p>
          </div>
        </div>
      </div>

      <div class="mt-12 flex gap-4">
        <a href="#" class="w-10 h-10 rounded bg-surface-container flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all">
          <span class="material-symbols-outlined">social_leaderboard</span>
        </a>
        <a href="#" class="w-10 h-10 rounded bg-surface-container flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all">
          <span class="material-symbols-outlined">camera</span>
        </a>
      </div>
    </div>

    <!-- Map Placeholder (Stylized for "Modern Archivist") -->
    <div class="md:w-1/2 h-96 bg-surface-container-high rounded-sm shadow-premium overflow-hidden relative group">
      <div class="absolute inset-0 bg-[url('https://maps.googleapis.com/maps/api/staticmap?center=-32.4842,-58.2329&zoom=15&size=600x400&scale=2&key=')] bg-cover bg-center grayscale opacity-50 transition-all group-hover:grayscale-0 group-hover:opacity-100"></div>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="bg-white/90 backdrop-blur-md p-6 rounded shadow-lg text-center border border-primary/10">
          <h5 class="font-headline font-bold text-primary mb-2">Visitanos en el Colegio</h5>
          <a href="https://maps.google.com" target="_blank" class="text-xs font-bold uppercase tracking-widest underline pointer-events-auto">Ver en Google Maps</a>
        </div>
      </div>
    </div>
  </div>
</section>
