---
const steps = [
  {
    number: "01",
    icon: "chat_bubble",
    title: "Nos contactás",
    description: "Completás el formulario, nos escribís por WhatsApp o nos llamás. Coordinamos para conocernos.",
    detail: "Sin compromisos. Solo una charla."
  },
  {
    number: "02",
    icon: "meeting_room",
    title: "Visita al colegio",
    description: "Te invitamos a recorrer las instalaciones, conocer a los docentes y vivir un día en el República.",
    detail: "Personal y sin apuros."
  },
  {
    number: "03",
    icon: "assignment",
    title: "Encuentro diagnóstico",
    description: "Realizamos una breve evaluación de competencias según el nivel, para personalizar el acompañamiento.",
    detail: "Adecuada a cada alumno."
  },
  {
    number: "04",
    icon: "celebration",
    title: "¡Bienvenido a la familia!",
    description: "Confirmamos la vacante y completamos la inscripción. Desde ese momento, son parte de nuestra comunidad.",
    detail: "El inicio de una historia."
  }
];
---

<section id="admisiones" class="py-28 bg-surface overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-10">

    <!-- Header -->
    <div class="text-center mb-20 reveal">
      <div class="section-label justify-center mb-4">Ciclo Lectivo 2026</div>
      <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-5">
        Proceso de ingreso<br/>
        <span class="italic font-normal" style="font-family:'Cormorant Garamond',serif; color: #1a6b2f;">simple y humano</span>
      </h2>
      <p class="text-on-surface-variant font-body font-light max-w-xl mx-auto text-[15px] leading-relaxed">
        Sabemos que elegir el colegio es una decisión importante. Por eso nuestro proceso está pensado para que te sientas acompañado en cada paso.
      </p>
    </div>

    <!-- Steps timeline -->
    <div class="relative mb-20">
      <!-- Connecting line (desktop) -->
      <div class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-px border-t-2 border-dashed border-outline-variant/30 z-0"></div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {steps.map((step, i) => (
          <div class={`reveal group relative z-10 flex flex-col items-center text-center delay-${i * 150}`}>
            <!-- Number bubble -->
            <div class="relative mb-6">
              <div class="w-24 h-24 rounded-full bg-surface-container-lowest border-2 border-outline-variant/20 flex items-center justify-center shadow-card group-hover:border-primary/30 group-hover:shadow-premium transition-all duration-500">
                <span class="material-symbols-outlined text-3xl text-primary" style="font-variation-settings:'FILL' 0,'wght' 200,'GRAD' 0,'opsz' 32;">{step.icon}</span>
              </div>
              <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-primary text-white text-[11px] font-bold flex items-center justify-center font-body shadow-sm">
                {step.number}
              </div>
            </div>

            <h3 class="font-headline text-xl font-bold mb-2 text-on-surface group-hover:text-primary transition-colors duration-300">{step.title}</h3>
            <p class="text-on-surface-variant text-sm font-body font-light leading-relaxed mb-3">{step.description}</p>
            <span class="text-[11px] italic text-on-surface-variant/60 font-body">{step.detail}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA Banner -->
    <div class="reveal rounded-3xl overflow-hidden relative" style="background: linear-gradient(135deg, #0e1c35 0%, #1a3a6e 60%, #2558a8 100%);">
      <!-- Background decorations -->
      <div class="absolute top-0 right-0 w-80 h-80 rounded-full opacity-10" style="background: #2d9e47; transform: translate(30%, -30%);"></div>
      <div class="absolute bottom-0 left-1/3 w-60 h-60 rounded-full opacity-8" style="background: #c0162a; transform: translateY(40%);"></div>
      
      <!-- Italian flag strip -->
      <div class="absolute top-0 left-0 right-0 h-1 flex">
        <div class="flex-1 bg-secondary/80"></div>
        <div class="flex-1 bg-white/30"></div>
        <div class="flex-1 bg-tertiary/80"></div>
      </div>

      <div class="relative z-10 p-10 md:p-16 flex flex-col md:flex-row items-center justify-between gap-10">
        <div class="text-white max-w-xl text-center md:text-left">
          <p class="text-white/50 text-xs uppercase tracking-widest font-bold mb-3 font-body">Inscripciones abiertas · 2026</p>
          <h3 class="font-headline text-3xl md:text-4xl font-bold mb-4 leading-tight">
            Vení a conocer<br/>
            <span class="italic font-normal" style="font-family:'Cormorant Garamond',serif; color: #c9a227;">el colegio en persona</span>
          </h3>
          <p class="text-white/60 font-body font-light text-sm leading-relaxed">
            Queremos que veas de primera mano cómo es el día a día. Coordinamos una visita personalizada, sin apuros.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 shrink-0 w-full md:w-auto">
          <a 
            href="https://wa.me/5493442123456" 
            target="_blank"
            class="flex items-center justify-center gap-2 bg-white text-primary px-8 py-4 rounded font-bold text-sm uppercase tracking-wider hover:bg-surface transition-all shadow-xl"
          >
            <span class="material-symbols-outlined text-[18px]">chat</span>
            WhatsApp
          </a>
          <a 
            href="#contacto"
            class="flex items-center justify-center gap-2 border-2 border-white/25 text-white px-8 py-4 rounded font-bold text-sm uppercase tracking-wider hover:bg-white/10 hover:border-white/40 transition-all"
          >
            <span class="material-symbols-outlined text-[18px]">mail</span>
            Formulario
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
