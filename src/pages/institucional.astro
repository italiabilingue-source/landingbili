---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Philosophy from '../components/Philosophy.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';

const title = "Institucional | Instituto República de Italia";
const description = "Conozca nuestra historia, valores y filosofía educativa. Más de 60 años formando ciudadanos del mundo en Concepción del Uruguay.";
---

<Layout title={title} description={description}>
  <Navbar />
  
  <main class="pt-10">
    <!-- Sobre nosotros: historia e identidad -->
    <About />

    <!-- Filosofía: la esencia -->
    <Philosophy />

    <!-- Por qué elegirnos: pilares -->
    <WhyChooseUs />
  </main>

  <Footer />
</Layout>

<style>
  main {
    overflow-x: hidden;
  }
</style>
