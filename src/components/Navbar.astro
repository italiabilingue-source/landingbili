---
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.jpg';

const navLinks = [
  { href: '#niveles', label: 'Niveles' },
  { href: '#vida-escolar', label: 'Vida Escolar' },
  { href: '#italiano', label: 'Italiano' },
  { href: '#deportes', label: 'Deportes' },
  { href: '#noticias', label: 'Noticias' },
  { href: '#contacto', label: 'Contacto' },
];
---

<nav id="main-nav" class="fixed top-0 z-[90] glass-nav w-full transition-all duration-500 transform -translate-y-full opacity-0">
  <div class="max-w-7xl mx-auto px-5 md:px-10 flex justify-between items-center h-16 md:h-[70px]">
    
    <!-- Logo & Brand -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Inicio - Instituto República de Italia">
      <div class="relative">
        <Image 
          src={logoImage} 
          alt="Logo Instituto República de Italia" 
          width={44} 
          height={44} 
          class="h-10 w-auto rounded-sm shadow-sm"
        />
        <!-- Italian flag micro accent -->
        <div class="absolute -bottom-1 -right-1 flex h-2 w-5 overflow-hidden rounded-sm shadow">
          <div class="flex-1 bg-secondary"></div>
          <div class="flex-1 bg-white"></div>
          <div class="flex-1 bg-tertiary"></div>
        </div>
      </div>
      <div class="flex flex-col leading-none">
        <span class="font-headline font-bold text-primary text-[15px] md:text-base tracking-tight group-hover:text-primary-light transition-colors">República de Italia</span>
        <span class="text-[9px] uppercase tracking-[0.22em] text-on-surface-variant font-semibold font-body hidden sm:block">Istituto Bilingue · Cdu</span>
      </div>
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden lg:flex items-center gap-1">
      {navLinks.map(link => (
        <a 
          href={link.href}
          class="relative text-[13px] font-medium text-on-surface-variant hover:text-primary px-3 py-2 rounded transition-colors duration-200 group"
        >
          {link.label}
          <span class="absolute bottom-1 left-3 right-3 h-[2px] bg-secondary scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-full"></span>
        </a>
      ))}
    </div>

    <!-- Desktop CTA + Mobile Controls -->
    <div class="flex items-center gap-3">
      <a 
        href="#contacto" 
        class="hidden md:inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded text-xs font-bold uppercase tracking-wider hover:bg-primary-light transition-all duration-200 shadow-md hover:shadow-lg"
      >
        <span class="material-symbols-outlined text-[16px]">school</span>
        Inscripciones
      </a>

      <!-- Mobile hamburger -->
      <button 
        id="mobile-menu-btn" 
        aria-label="Abrir menú"
        class="lg:hidden flex flex-col gap-1.5 p-2 rounded group"
      >
        <span class="block w-5 h-0.5 bg-primary transition-all duration-300" id="bar1"></span>
        <span class="block w-5 h-0.5 bg-primary transition-all duration-300" id="bar2"></span>
        <span class="block w-4 h-0.5 bg-primary transition-all duration-300 self-end" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Drawer -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-outline-variant/10 bg-surface/98 backdrop-blur-xl px-5 pb-8 pt-4">
    <div class="flex flex-col gap-1">
      {navLinks.map((link, i) => (
        <a 
          href={link.href}
          class="mobile-nav-link flex items-center gap-3 px-3 py-3.5 rounded-md text-[15px] font-medium text-on-surface hover:bg-surface-container hover:text-primary transition-all duration-200"
          style={`animation-delay: ${i * 60}ms`}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="mt-6 pt-5 border-t border-outline-variant/15">
      <a 
        href="#contacto"
        id="mobile-cta"
        class="flex items-center justify-center gap-2 bg-primary text-white px-6 py-4 rounded font-bold uppercase tracking-widest text-sm w-full hover:bg-primary-light transition-colors"
      >
        <span class="material-symbols-outlined text-[18px]">school</span>
        Solicitar Inscripción
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  // Show / hide navbar on scroll
  window.addEventListener('scroll', () => {
    if (!nav) return;
    if (window.scrollY > 80) {
      nav.classList.remove('-translate-y-full', 'opacity-0');
      nav.classList.add('translate-y-0', 'opacity-100');
    } else {
      nav.classList.add('-translate-y-full', 'opacity-0');
      nav.classList.remove('translate-y-0', 'opacity-100');
      // Close mobile menu on scroll to top
      if (mobileMenu) mobileMenu.classList.add('hidden');
    }
  });

  // Toggle mobile menu
  let menuOpen = false;
  mobileBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (mobileMenu) mobileMenu.classList.toggle('hidden', !menuOpen);
    // Animate hamburger → X
    if (bar1) bar1.style.transform = menuOpen ? 'translateY(8px) rotate(45deg)' : '';
    if (bar2) bar2.style.opacity = menuOpen ? '0' : '1';
    if (bar3) bar3.style.transform = menuOpen ? 'translateY(-8px) rotate(-45deg)' : '';
    if (bar3) bar3.style.width = menuOpen ? '1.25rem' : '';
  });

  // Close menu on link click
  document.querySelectorAll('.mobile-nav-link, #mobile-cta').forEach(link => {
    link.addEventListener('click', () => {
      menuOpen = false;
      if (mobileMenu) mobileMenu.classList.add('hidden');
      if (bar1) bar1.style.transform = '';
      if (bar2) bar2.style.opacity = '1';
      if (bar3) bar3.style.transform = '';
      if (bar3) bar3.style.width = '';
    });
  });

  // Highlight active section in nav
  const sections = document.querySelectorAll('section[id]');
  const navLinkEls = document.querySelectorAll('nav a[href^="#"]');

  const activeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinkEls.forEach(a => {
          const href = a.getAttribute('href');
          if (href === `#${entry.target.id}`) {
            a.classList.add('text-primary');
          } else {
            a.classList.remove('text-primary');
          }
        });
      }
    });
  }, { threshold: 0.4 });

  sections.forEach(s => activeObserver.observe(s));
</script>
