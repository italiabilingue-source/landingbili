---
export interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
  ctaText?: string;
  ctaLink?: string;
}

const { title, subtitle, backgroundImage, ctaText, ctaLink } = Astro.props;
---

<section class="relative h-96 flex items-center justify-center text-white overflow-hidden">
  <div class="absolute inset-0 z-0">
    {backgroundImage ? (
      <img src={backgroundImage} alt="Hero" class="w-full h-full object-cover" />
    ) : (
      <div class="w-full h-full bg-gradient-to-r from-italia-rojo to-italia-verde"></div>
    )}
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <div class="relative z-10 text-center px-4">
    <h1 class="text-4xl md:text-5xl font-bold mb-4 drop-shadow-lg">{title}</h1>
    {subtitle && (
      <p class="text-xl md:text-2xl mb-8 drop-shadow-lg">{subtitle}</p>
    )}
    {ctaText && ctaLink && (
      <a
        href={ctaLink}
        class="inline-block px-8 py-3 bg-italia-rojo hover:bg-italia-verde text-white font-bold rounded-lg transition-colors shadow-lg"
      >
        {ctaText}
      </a>
    )}
  </div>
</section>
