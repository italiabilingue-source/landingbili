---
---
<section id="contacto" class="relative bg-surface overflow-hidden py-16">
  
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.025] pointer-events-none">
    <div class="w-full h-full" style="background: radial-gradient(ellipse at top right, #1a3a6e, transparent 60%);"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-10 relative z-10">

    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <div class="section-label justify-center mb-4">Estamos para vos</div>
      <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-5">
        Hablemos sin<br/>
        <span class="italic font-normal" style="font-family:'Cormorant Garamond',serif; color: #1a3a6e;">apuros</span>
      </h2>
      <p class="text-on-surface-variant font-body font-light max-w-xl mx-auto text-[15px] leading-relaxed">
        Resolvemos tus dudas de forma simple y directa. Elegí el medio que más te resulte cómodo.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">

      <!-- Left: Info + Quick Actions -->
      <div class="flex flex-col gap-6 reveal-left">
        
        <!-- Contact cards -->
        <div class="space-y-4">
          {[
            { icon: 'location_on', label: 'Dirección', value: 'Av. del Libertador 1234, Concepción del Uruguay, Entre Ríos', color: '#1a6b2f' },
            { icon: 'mail', label: 'Email institucional', value: 'informes@itbili.edu.ar', color: '#1a3a6e' },
            { icon: 'phone_iphone', label: 'WhatsApp de Admisiones', value: '+54 9 3442 123456', color: '#c0162a', bold: true },
          ].map(item => (
            <div class="flex items-start gap-5 p-6 rounded-2xl bg-surface-container-lowest border border-outline-variant/10 hover:shadow-card transition-all duration-300">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0" style={`background: ${item.color}15;`}>
                <span class="material-symbols-outlined text-xl" style={`color: ${item.color}; font-variation-settings:'FILL' 1,'wght' 300,'GRAD' 0,'opsz' 24;`}>{item.icon}</span>
              </div>
              <div>
                <p class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant mb-1 font-body">{item.label}</p>
                <p class={`text-sm font-body leading-relaxed ${item.bold ? 'font-bold text-base' : ''}`} style={item.bold ? `color: ${item.color}` : ''}>{item.value}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Quick WhatsApp CTA -->
        <a 
          href="https://wa.me/5493442123456?text=Hola%2C%20me%20gustar%C3%ADa%20obtener%20informaci%C3%B3n%20sobre%20el%20colegio."
          target="_blank"
          class="flex items-center justify-center gap-3 py-5 rounded-2xl font-bold text-white text-sm uppercase tracking-widest transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, #128c38 0%, #25d366 100%);"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.134.558 4.134 1.533 5.875L.054 23.25c-.09.36.216.666.576.576l5.508-1.433A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9A9.9 9.9 0 012.1 12 9.9 9.9 0 0112 2.1a9.9 9.9 0 019.9 9.9A9.9 9.9 0 0112 21.9z"/>
          </svg>
          Escribirnos por WhatsApp
        </a>

        <!-- Map embed placeholder -->
        <div class="rounded-2xl overflow-hidden h-52 bg-surface-container-high border border-outline-variant/10 relative group">
          <div class="absolute inset-0 bg-surface-container-highest flex items-center justify-center">
            <div class="text-center">
              <span class="material-symbols-outlined text-5xl text-primary/30 block mb-2" style="font-variation-settings:'FILL' 1,'wght' 300,'GRAD' 0,'opsz' 48;">map</span>
              <a 
                href="https://maps.google.com/?q=Concepción+del+Uruguay+Entre+Rios+Argentina" 
                target="_blank"
                class="text-xs font-bold uppercase tracking-widest text-primary hover:text-primary-light transition-colors font-body"
              >
                Ver en Google Maps →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="reveal-right">
        <div class="bg-surface-container-lowest rounded-3xl p-8 md:p-10 border border-outline-variant/10 shadow-card" style="border-top: 3px solid #1a3a6e;">
          <h3 class="font-headline text-2xl font-bold mb-2 text-on-surface">Envianos tu consulta</h3>
          <p class="text-on-surface-variant text-sm font-body font-light mb-8">Respondemos en menos de 24 horas hábiles.</p>

          <form class="space-y-5" id="contact-form">
            <div class="grid sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label for="nombre" class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant font-body">Nombre completo</label>
                <input 
                  type="text" id="nombre" name="nombre" required
                  placeholder="Ej. María García"
                  class="bg-surface border border-outline-variant/25 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 font-body"
                >
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="telefono" class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant font-body">Teléfono</label>
                <input 
                  type="tel" id="telefono" name="telefono"
                  placeholder="Ej. 3442 123456"
                  class="bg-surface border border-outline-variant/25 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 font-body"
                >
              </div>
            </div>
            
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant font-body">Email</label>
              <input 
                type="email" id="email" name="email" required
                placeholder="tu@email.com"
                class="bg-surface border border-outline-variant/25 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 font-body"
              >
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="nivel" class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant font-body">Nivel de interés</label>
              <select id="nivel" name="nivel" class="bg-surface border border-outline-variant/25 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 font-body text-on-surface-variant">
                <option value="">Seleccioná el nivel…</option>
                <option value="jardin">Jardín (3, 4 y 5 años)</option>
                <option value="primaria">Escuela Primaria (1° a 6°)</option>
                <option value="secundaria">Escuela Secundaria (1° a 6°)</option>
                <option value="general">Información general</option>
              </select>
            </div>
            
            <div class="flex flex-col gap-1.5">
              <label for="mensaje" class="text-[11px] font-bold uppercase tracking-widest text-on-surface-variant font-body">Mensaje</label>
              <textarea 
                id="mensaje" name="mensaje" rows="4"
                placeholder="¿En qué te podemos ayudar?"
                class="bg-surface border border-outline-variant/25 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-200 resize-none font-body"
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full flex items-center justify-center gap-2.5 bg-primary text-white py-4 rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-primary-light transition-all duration-300 shadow-lg hover:shadow-primary/30 hover:-translate-y-0.5 mt-2 font-body"
            >
              <span class="material-symbols-outlined text-[18px]">send</span>
              Enviar consulta
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>
