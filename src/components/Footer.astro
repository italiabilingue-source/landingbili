---
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.jpg';
---

<footer class="bg-on-surface text-white overflow-hidden relative">
  
  <!-- Italian flag top strip -->
  <div class="w-full h-1 flex">
    <div class="flex-1 bg-secondary"></div>
    <div class="flex-1 bg-white/30"></div>
    <div class="flex-1 bg-tertiary"></div>
  </div>

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-6 md:px-10 pt-16 pb-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">

      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-6">
          <Image 
            src={logoImage}
            alt="Logo Instituto República de Italia"
            width={48}
            height={48}
            class="h-12 w-auto rounded-md opacity-90"
          />
          <div>
            <span class="font-headline font-bold text-white text-lg block leading-none">República de Italia</span>
            <span class="text-white/40 text-[10px] uppercase tracking-[0.25em] font-body font-medium">Instituto Bilingüe</span>
          </div>
        </div>

        <p class="text-white/50 text-sm font-body font-light leading-relaxed max-w-sm mb-8">
          Más de 60 años formando personas con identidad, valores y bilinguismo ítalo-español en el corazón de Concepción del Uruguay, Entre Ríos.
        </p>

        <p class="text-white/30 text-[11px] font-body uppercase tracking-widest mb-8">Bilingüismo Italiano · Español</p>

        <!-- Social links -->
        <div class="flex gap-3">
          <a 
            href="#" 
            aria-label="Facebook"
            class="w-10 h-10 rounded-xl border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/25 hover:bg-white/5 transition-all duration-300"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.324v-21.35c0-.732-.593-1.325-1.325-1.325z"/>
            </svg>
          </a>
          <a 
            href="#" 
            aria-label="Instagram"
            class="w-10 h-10 rounded-xl border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/25 hover:bg-white/5 transition-all duration-300"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a 
            href="https://wa.me/5493442123456"
            target="_blank"
            aria-label="WhatsApp"
            class="w-10 h-10 rounded-xl border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-secondary/50 hover:bg-secondary/10 transition-all duration-300"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.134.558 4.134 1.533 5.875L.054 23.25c-.09.36.216.666.576.576l5.508-1.433A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9A9.9 9.9 0 012.1 12 9.9 9.9 0 0112 2.1a9.9 9.9 0 019.9 9.9A9.9 9.9 0 0112 21.9z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-body font-bold text-[11px] uppercase tracking-[0.22em] text-white/35 mb-6">El colegio</h4>
        <nav class="flex flex-col gap-3">
          {[
            { href: '/niveles', label: 'Jardín, Primaria y Secundaria' },
            { href: '/institucional', label: 'Nuestra historia' },
            { href: '/admisiones', label: 'Proceso de admisión' },
            { href: '/noticias', label: 'Noticias y eventos' },
            { href: '/contacto', label: 'Contacto' },
          ].map(link => (
            <a href={link.href} class="text-sm text-white/50 hover:text-white transition-colors duration-200 font-body hover:translate-x-0.5 transform inline-block">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact quick -->
      <div>
        <h4 class="font-body font-bold text-[11px] uppercase tracking-[0.22em] text-white/35 mb-6">Contacto rápido</h4>
        <div class="flex flex-col gap-5">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-[16px] mt-0.5 text-secondary shrink-0" style="font-variation-settings:'FILL' 1,'wght' 300,'GRAD' 0,'opsz' 20;">location_on</span>
            <p class="text-sm text-white/50 font-body font-light leading-relaxed">Av. del Libertador 1234,<br/>Concepción del Uruguay, E.R.</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[16px] text-secondary shrink-0" style="font-variation-settings:'FILL' 1,'wght' 300,'GRAD' 0,'opsz' 20;">mail</span>
            <a href="mailto:informes@itbili.edu.ar" class="text-sm text-white/50 hover:text-white transition-colors font-body">informes@itbili.edu.ar</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[16px] text-secondary shrink-0" style="font-variation-settings:'FILL' 1,'wght' 300,'GRAD' 0,'opsz' 20;">phone_iphone</span>
            <a href="https://wa.me/5493442123456" target="_blank" class="text-sm font-bold text-white/70 hover:text-white transition-colors font-body">+54 9 3442 12-3456</a>
          </div>

          <a 
            href="/admisiones"
            class="mt-2 inline-flex items-center gap-2 border border-white/15 text-white/60 hover:text-white hover:border-white/30 text-xs font-bold uppercase tracking-widest px-5 py-2.5 rounded-lg transition-all duration-300 font-body"
          >
            <span class="material-symbols-outlined text-[14px]">school</span>
            Inscripciones 2026
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-[11px] text-white/25 font-body uppercase tracking-widest">
        © 2026 Instituto Bilingüe República de Italia · Todos los derechos reservados
      </p>
      <div class="flex items-center gap-6 text-[11px] text-white/25 font-body uppercase tracking-widest">
        <a href="#" class="hover:text-white/50 transition-colors">Privacidad</a>
        <span>·</span>
        <span>Concepción del Uruguay, Entre Ríos</span>
      </div>
    </div>
  </div>
</footer>
