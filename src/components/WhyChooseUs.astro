---
const reasons = [
  {
    icon: "history_edu",
    title: "Trayectoria",
    description: "Más de 60 años formando generaciones con un sello de prestigio y compromiso educativo en la comunidad."
  },
  {
    icon: "translate",
    title: "Educación Bilingüe",
    description: "Inmersión natural en el idioma inglés desde sala de 3, con certificaciones internacionales y enfoque global."
  },
  {
    icon: "groups",
    title: "Acompañamiento Cercano",
    description: "Grupos reducidos que permiten un seguimiento personalizado de cada alumno y su desarrollo socio-emocional."
  },
  {
    icon: "military_tech",
    title: "Formación Integral",
    description: "Equilibrio entre exigencia académica, valores éticos y el desarrollo de talentos deportivos y artísticos."
  }
];
---

<section class="py-24 bg-surface text-on-surface">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16">
      <h2 class="font-headline text-4xl md:text-5xl mb-4 text-primary">Por qué elegirnos</h2>
      <div class="w-20 h-1 bg-secondary"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
      {reasons.map((reason) => (
        <div class="flex flex-col">
          <div class="mb-6 text-secondary flex items-center justify-center w-12 h-12 rounded bg-surface-container-low">
            <span class="material-symbols-outlined text-3xl">{reason.icon}</span>
          </div>
          <h3 class="font-headline text-xl mb-3 font-bold">{reason.title}</h3>
          <p class="text-on-surface-variant leading-relaxed text-sm">
            {reason.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
