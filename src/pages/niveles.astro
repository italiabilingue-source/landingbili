---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AcademicPrograms from '../components/AcademicPrograms.astro';
import SchoolLife from '../components/SchoolLife.astro';
import ItalianBanner from '../components/ItalianBanner.astro';
import Footer from '../components/Footer.astro';

const title = "Propuesta Educativa | Jardín, Primaria y Secundaria";
const description = "Explora nuestros niveles educativos bilingües. Desde nivel inicial hasta secundaria, con certificaciones internacionales y enfoque integral.";
---

<Layout title={title} description={description}>
  <Navbar />
  
  <main class="pt-10">
    <!-- Niveles educativos -->
    <AcademicPrograms />

    <!-- Vida escolar: grid fotográfico -->
    <SchoolLife />

    <!-- El italiano + Deportes -->
    <ItalianBanner />
  </main>

  <Footer />
</Layout>

<style>
  main {
    overflow-x: hidden;
  }
</style>
