---
---
<!-- Floating WhatsApp Button -->
<div id="whatsapp-float" class="fixed bottom-6 right-6 z-[100] flex flex-col items-end gap-3">

  <!-- Tooltip bubble (shows on hover) -->
  <div 
    id="wa-tooltip"
    class="opacity-0 translate-x-4 pointer-events-none transition-all duration-300 ease-out"
  >
    <div class="bg-white rounded-2xl shadow-[0_8px_32px_rgba(0,0,0,0.18)] px-5 py-4 max-w-[220px] border border-surface-container-high relative">
      <div class="absolute -right-2 bottom-4 w-4 h-4 bg-white rotate-45 border-r border-b border-surface-container-high"></div>
      <p class="text-on-surface text-[13px] font-medium font-body mb-0.5">¿Tenés una consulta?</p>
      <p class="text-on-surface-variant text-xs font-body font-light">Respondemos en minutos 💬</p>
    </div>
  </div>

  <!-- WhatsApp button -->
  <a 
    id="wa-btn"
    href="https://wa.me/5493442123456?text=Hola%2C%20me%20gustar%C3%ADa%20obtener%20informaci%C3%B3n%20sobre%20el%20Instituto%20Rep%C3%BAblica%20de%20Italia."
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contactar por WhatsApp"
    class="group relative w-16 h-16 rounded-full flex items-center justify-center shadow-[0_8px_28px_rgba(37,211,102,0.45)] hover:shadow-[0_12px_36px_rgba(37,211,102,0.6)] transition-all duration-300 hover:scale-110"
    style="background: linear-gradient(135deg, #128c38 0%, #25d366 100%);"
  >
    <!-- Pulse rings -->
    <span class="absolute inset-0 rounded-full animate-ping opacity-20" style="background: #25d366;"></span>
    <span class="absolute inset-0 rounded-full animate-ping opacity-10 animation-delay-500" style="background: #25d366; animation-delay: 0.5s;"></span>
    
    <!-- WhatsApp SVG icon -->
    <svg class="w-8 h-8 text-white relative z-10" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.134.558 4.134 1.533 5.875L.054 23.25c-.09.36.216.666.576.576l5.508-1.433A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.9A9.9 9.9 0 012.1 12 9.9 9.9 0 0112 2.1a9.9 9.9 0 019.9 9.9A9.9 9.9 0 0112 21.9z"/>
    </svg>
  </a>
</div>

<script>
  const btn = document.getElementById('wa-btn');
  const tooltip = document.getElementById('wa-tooltip');

  // Show tooltip on hover
  btn?.addEventListener('mouseenter', () => {
    if (tooltip) {
      tooltip.style.opacity = '1';
      tooltip.style.transform = 'translateX(0)';
      tooltip.style.pointerEvents = 'none';
    }
  });

  btn?.addEventListener('mouseleave', () => {
    if (tooltip) {
      tooltip.style.opacity = '0';
      tooltip.style.transform = 'translateX(16px)';
    }
  });

  // Auto show tooltip after 5s page load (once)
  let tooltipShown = false;
  setTimeout(() => {
    if (!tooltipShown && tooltip) {
      tooltipShown = true;
      tooltip.style.opacity = '1';
      tooltip.style.transform = 'translateX(0)';
      setTimeout(() => {
        if (tooltip) {
          tooltip.style.opacity = '0';
          tooltip.style.transform = 'translateX(16px)';
        }
      }, 4000);
    }
  }, 5000);
</script>
